<!DOCTYPE html>
<html lang="tr">
	<head>
		{% block page_styles %}{% endblock %}
	</head>
	<body class="current-page-{{ site.route.group }}-{{ site.route.name }}">
		{% include 'html/snippets/header.twig' %}
		<main id="main">
			<div class="container">
                <section>
                    {% block breadcrumb %}{% endblock %}
                    {% block content %}{% endblock %}
                </section>
			</div>
		</main>
        {% include 'html/snippets/footer.twig' %}
		{% include 'html/snippets/scripts.twig' %}
		{% block page_scripts %}{% endblock %}
	</body>
</html>