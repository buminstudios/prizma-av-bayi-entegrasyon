{% extends 'html/layouts/content-only.twig' %}
{% import 'html/snippets/icon-set.twig' as iconset %}
{% block page_scripts %}
	<script type="text/javascript" src="{{ themeAsset('javascript/jquery.elevatezoom.js') }}"></script>
	<script type="text/javascript" src="{{ themeAsset('javascript/rateyo.js') }}"></script>
	<script type="text/javascript" src="{{ themeAsset('javascript/product.js') }}"></script>
{% endblock %}
{% block content %}
<div id="product-detail-container">
	{% include 'html/snippets/product/breadcrumb.twig' %}
	<div class="product-area-top">
		<div class="row">
			<div class="col-lg-6">
                <div class="product-left">
					<div class="product-image">
						<div id="product-primary-image">
							{% if product.images | length > 0 %}
								<img loading="lazy" decoding="async" id="primary-image" alt="{{ product.primaryImage.alt | default(product.fullName) }}" src="{{ product.primaryImage.originalUrl }}" data-zoom-image="{{ product.primaryImage.originalUrl }}" />
							{% else %}
								<img loading="lazy" decoding="async" class="product-no-picture" alt="{{ product.primaryImage.alt | default(product.fullName) }}" src="{{ product.primaryImage.originalUrl | default(getNopicImageUrl()) }}" />
							{% endif %}
						</div>
                        {% if product.productExtraFields.product_extra_field_1 %}
                            <div class="product-extra-fields">
                                <a data-fancybox href="{{ product.productExtraFields.product_extra_field_1 }}">
                                    {{ iconset.iconProductVideo() }}
                                    <span>{{ theme.settings.product_video_title }}</span>
                                </a>                                
                            </div>
                        {% endif %}
					</div>
					{% if product.images | length > 0 %}
						<div id="product-thumb-image" class="row">
							{% for image in product.images %}
								{% if image.thumbUrl %}
									<div class="thumb-item col-auto">
										<a href="#" data-image="{{ image.originalUrl }}" data-zoom-image="{{ image.originalUrl }}">
                                            <img loading="lazy" decoding="async" src="{{ image.thumbUrl }}" alt="{{ image.alt | default(product.fullName) }}">
                                        </a>
									</div>
								{% endif %}
							{% endfor %}
						</div>
					{% endif %}
				</div>
			</div>
			<div class="col-lg-6">
				<div class="product-right">
                    <div class="product-list-group">
                        <div class="product-right-top">
                            <div class="product-title-and-brand">
                                {% if product.brand %}
                                    <div class="product-brand-title">
                                        <a href="{{ product.brand.url }}">{{ product.brand.name }}</a>
                                    </div>
                                {% endif %}
                                <div class="product-title">
                                    <h1 class="section-title">{{ product.fullName }}</h1>
                                </div>
                            </div>
                            {% if product.brand and theme.settings.display_brand_detail %}
                                <div class="product-brand{% if theme.settings.brand_view_type == 'logo' %} product-brand-image{% endif %}">
                                    <a href="{{ product.brand.url }}" title="{{ product.brand.name ~ ' ' ~ theme.settings.detail_brand_text }}">
                                        {% if theme.settings.brand_view_type == "logo" %}
                                            {% if product.brand.imageUrl %}
                                                <img loading="lazy" decoding="async" src="{{ product.brand.imageUrl }}" alt="" />
                                            {% else %}
                                                <img loading="lazy" decoding="async" src="{{ themeAsset(theme.settings.nopic_image) }}" alt="">
                                            {% endif %}
                                        {% elseif theme.settings.brand_view_type == "name" %}
                                            <span>{{ product.brand.name }}</span>
                                        {% endif %}
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                        <div class="product-comments-container" data-selector="add-comment">
                            <div class="product-comment-rating" data-rank="{{ product.averageCommentRank | number_format(2, '.', ',') }}"></div>
                            <span>{{ product.CommentCount }} {{ theme.settings.product_add_comment_title }}</span>
                        </div>
                        <div class="product-price-container">
                            {% if product.isDiscounted %}
                                <div class="discount-label">%{{ product.discountPercent }} {{ theme.settings.label_discount }}</div>
                            {% endif %}
                            {% if preferences.sales_allowed %}
                                <div class="product-price{% if product.isDiscounted %} has-discount{% endif %}">                                
                                    <div class="product-price-new">
                                        {{ product.discountedPriceWithTax(preferences.default_currency) | money }} {{ preferences.default_currency }}
                                    </div>
                                    {% if product.isDiscounted %}
                                        <div class="product-price-old">
                                            {{ product.priceWithTax(preferences.default_currency) | money }} {{ preferences.default_currency }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="product-right-middle">
                            {% if product.isDiscounted %}
                                <div class="product-gain-price">
                                    {{ iconset.iconProductGain() }}
                                    <div>
                                        <span>{{ theme.settings.product_gain_title }}</span>
                                        <strong>{{ (product.priceWithTax(preferences.default_currency) - product.discountedPriceWithTax(preferences.default_currency)) | money }} {{ preferences.default_currency }}</strong>
                                    </div>                                    
                                </div>
                            {% endif %}
                            {% if product.hasGift %}
                                <div class="gift-label">
                                    {{ iconset.iconGiftLabel() }}
                                    <span>{{ theme.settings.label_gift }}</span>
                                </div>
                            {% endif %}
                            {% if product.lowestPrice and theme.settings.display_product_lowest_price %}
                                <div class="product-text-danger">
                                    {{ iconset.iconTextDanger() }}
                                    <span>{{ getLang("_LowestInstallment_") | replace({'(arg0)' : (product.lowestPrice | money) ~ ' ' ~ preferences.default_currency }) }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="product-list-group">
                        <div class="product-list-container">
                            {% if product.categories | length > 0 and theme.settings.display_category_detail %}
                                <div class="product-list-row product-categories">
                                    <div class="product-list-title">{{ getLang("_Category_") }}</div>
                                    <div class="product-list-content">
                                        <span>
                                            {% for category in product.categories %}
                                                <a href='{{ category.url }}' title="{{ category.name ~ ' ' ~ theme.settings.detail_category_text }}">{{ category.name }}</a>
                                                {% if not loop.last %}<span>, </span>{% endif %}
                                            {% endfor %}
                                        </span>
                                    </div>
                                </div>
                            {% endif %}
                            {% if product.collections | length > 0 and theme.settings.display_collection_detail %}
                                <div class="product-list-row product-collections">
                                    <div class="product-list-title">{{ getLang("_Collection_") }}</div>
                                    <div class="product-list-content">
                                        <span>
                                            {% for collection in product.collections %}
                                                <a href='{{ collection.url }}' title="{{ collection.name }}">{{ collection.name }}</a>
                                                {% if not loop.last %}<span>, </span>{% endif %}
                                            {% endfor %}
                                        </span>
                                    </div>
                                </div>
                            {% endif %}
                            {% if theme.settings.display_sku %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_StockCode_") }}</div>
                                    <div class="product-list-content">{{ product.sku }}</div>
                                </div>
                            {% endif %}
                            {% if product.barcode and theme.settings.display_barcode %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_BarcodeCode_") }}</div>
                                    <div class="product-list-content">{{ product.barcode }}</div>
                                </div>
                            {% endif %}
                            {% for selectionGroup in product.selectionGroups %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ selectionGroup.name }}</div>
                                    <div class="product-list-content">
                                        <div class="selectbox">
                                            <select class="form-control" data-selector="selection-group" data-id="{{ selectionGroup.id }}" data-name="{{ selectionGroup.name }}">
                                                <option value="">{{ getLang("_Choose_") }}</option>
                                                {% for selection in selectionGroup.selections %}
                                                    <option value="{{ selection.name }}">
                                                        {{ selection.name }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                            {% for labelGroup in product.labelGroups %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ labelGroup.name }}</div>
                                    <div class="product-list-content">
                                        <span>
                                            {% for label in labelGroup.labels %}
                                                <a href="{{ label.url }}" title="{{ label.name ~ ' ' ~ theme.settings.detail_label_text }}">
                                                    {{ label.name }}
                                                </a>
                                                {% if not loop.last %}<span>, </span>{% endif %}
                                            {% endfor %}
                                        </span>
                                    </div>
                                </div>
                            {% endfor %}
                            {% for extraInfo in product.extraInfos %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ extraInfo.name }}</div>
                                    <div class="product-list-content">{{ extraInfo.value }}</div>
                                </div>
                            {% endfor %}
                            {% if product.hasGift and product.gift %}
                                <div class="product-list-row">
                                    <div class="product-list-title">
                                        {{ getLang('_Gift_') }}
                                    </div>
                                    <div class="product-list-content">{{ product.gift }}</div>
                                </div>
                            {% endif %}
                            {% if product.hasWarranty and theme.settings.display_warranty %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_Warranty_") }}</div>
                                    <div class="product-list-content">{{ product.warranty }}&nbsp;{{ getLang("_Month_") }}</div>
                                </div>
                            {% endif %}
                            {% if product.marketPriceDetail %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_MarketPrice_") }}</div>
                                    <div class="product-list-content">
                                        {{ product.marketPriceDetail | raw }}
                                    </div>
                                </div>
                            {% endif %}
                            {% if product.isEligibleRetailerComparisonPrice and theme.settings.display_retailer_comparison_price %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_Price_") }}</div>
                                    <div class="product-list-content">
                                        {{ product.retailerComparisonPrice | money }} {{ product.currency }} + {{ getLang("_Tax_") }}
                                    </div>
                                </div>
                            {% endif %}
                            {% if preferences.sales_allowed and theme.settings.display_without_tax_price %}
                                <div class="product-list-row">
                                    <div class="product-list-title">
                                        {% if product.isEligibleRetailerComparisonPrice and theme.settings.display_retailer_comparison_price %}
                                            {{ getLang("_PartnerPrice_") }}
                                        {% elseif preferences.sales_allowed %}
                                            {{ getLang("_Price_") }}
                                        {% endif %}
                                    </div>
                                    <div class="product-list-content">{{ product.priceWithoutTax(product.currency) | money }} {{ product.currency }} + {{ getLang("_Tax_") }}</div>
                                </div>
                            {% endif %}
                            {% if product.isEligibleMoneyOrderDiscount %}
                                <div class="product-list-row">
                                    <div class="product-list-title">{{ getLang("_MoneyOrder_") }}</div>
                                    <div class="product-list-content">
                                        {{ product.moneyOrderPriceWithTax(preferences.default_currency) | money }} {{ preferences.default_currency }}
                                        {% if product.isEligibleMoneyOrderDiscount %}
                                            <span>{{ getLang("_BankTransferMsg_") | replace({'(arg0)' : product.moneyOrderDiscount | money }) }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}                            
                        </div>
                        {% if theme.settings.product_detail_cargo %}
                            <div class="product-detail-cargo">
                                {{ iconset.iconProductCargo() }}
                                <span>{{ theme.settings.product_detail_cargo }}</span>
                            </div>
                        {% endif %}
                        {% if product.isVariantAvailable %}
                            <div class="product-options">
                                {% if theme.settings.optioned_product_view_type == "radiobox_multiple"  %}
                                    <div class="variant-group-title">{{ getLang("_Options_") }}</div>
                                {% endif %}
                                {% include "html/snippets/product/option.twig" %}
                            </div>
                        {% endif %}
                        {% if product.customization  %}
                            <div class="product-list-block">
                                {% include 'html/snippets/product/customization.twig' %}
                            </div>
                        {% endif %}
                        {% if preferences.sales_allowed %}
                            {% if product.isAvailableForSales %}
                                {% if theme.settings.qtytype == 'select' or theme.settings.qtytype == "textbox" or theme.settings.qtytype == "plusminus" %}
                                    {% if theme.settings.qtytype == "select" %}
                                        <div class="product-qty" data-selector="qty-wrapper">
                                            <select name="qty-input" id="qty-input" data-selector="qty" data-context="detail" data-stocktype="{{ product.stockTypeLabel }}" data-stockamount='{{ product.stockAmount }}' value="1" aria-label="Quantity">
                                                {% for i in 1..10 %}
                                                    <option value="{{ i }}">{{ i }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    {% elseif theme.settings.qtytype == "textbox" %}
                                        <div class="product-qty" data-selector="qty-wrapper">
                                            <input type="text" id="qty-input" data-selector="qty" data-context="detail" data-stocktype="{{ product.stockTypeLabel }}" data-stockamount='{{ product.stockAmount }}' value="1" aria-label="Quantity" autocomplete="off">
                                        </div>
                                    {% elseif theme.settings.qtytype == "plusminus" %}
                                        <div class="product-qty" data-selector="qty-wrapper">
                                            <a href="javascript:void(0)" class="product-qty-minus" data-selector="decrease-qty" aria-label="Decrease Quantity">
                                                {{ iconset.iconMinus() }}
                                            </a>
                                            <input type="text" id="qty-input" data-selector="qty" data-context="detail" data-stocktype="{{ product.stockTypeLabel }}" data-stockamount='{{ product.stockAmount }}' value="1" aria-label="Quantity" autocomplete="off">
                                            <a href="javascript:void(0)" class="product-qty-plus" data-selector="increase-qty" aria-label="Increase Quantity">
                                                {{ iconset.iconPlus() }}
                                            </a>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            {% endif %}
                        {% endif %}
                        {% if preferences.sales_allowed %}
                            <div class="product-cart-buttons">
                                {% if product.isAvailableForSales %}
                                    {% if product.realAmount > 0 %}
                                        <div class="product-add-to-cart-button">
                                            <a href="javascript:void(0);" class="btn btn-primary add-to-cart-button" data-selector="add-to-cart" data-context="detail" data-product-id="{{ product.id }}"><span>{{ theme.settings.addtocart_button }}</span></a>
                                        </div>
                                        <div class="product-quick-order-button">
                                            <a href="javascript:void(0);" class="btn btn-primary quick-order-button" data-selector="add-to-cart" data-context="quick" data-product-id="{{ product.id }}"><span>{{ theme.settings.quickorder_button }}</span></a>
                                        </div>
                                    {% else %}
                                        <div class="product-no-stock-button">
                                            <a href="javascript:void(0);" class="btn btn-secondary no-stock-button">{{ theme.settings.nostock_button }}</a>
                                        </div>
                                    {% endif %}
                                {% elseif product.stockAmount == 0 %}
                                    <div class="product-remind-me-button">
                                        <a href="javascript:void(0);" class="btn btn-primary remind-me-button" data-selector="stock-warning">{{ theme.settings.remindme_button }}</a>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
					{% if product.buttons | length > 0 and theme.settings.display_cargo_buttons %}
                        <div class="product-standart-cargo-buttons">
                            {% for productButton in product.buttons %}
                                <div class="product-standart-cargo-button {{ productButton.name }}">
                                    <i></i>
                                    <span>{{ getLang('_' ~ productButton.name ~ '_') }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if theme.settings.display_user_buttons %}
                        <div id="product-user-buttons">
                            {% if theme.settings.display_favori_buttons %}
                                <div>
                                    <a href="javascript:void(0);" class="add-my-favorites{{ isFavoriteProduct(product.id) ? ' favorite-product' }}" data-selector="add-my-favorites" data-product-id="{{ product.id }}" aria-label="Add To Favorites">
                                        <div class="icon-favori">
                                            {{ iconset.iconFavori() }}
                                        </div>
                                        <div class="icon-favori-add">
                                            {{ iconset.iconFavoriAdd() }}
                                        </div>
                                        <span data-favorite-product="{{ theme.settings.user_favorite_product }}" data-add-to-favorites="{{ theme.settings.user_add_my_favorites }}"></span>
                                    </a>
                                </div>
                            {% endif %}
                            {% if product.isPriceDiscountNotifiable %}
                                <div>
                                    <a href="javascript:void(0);" class="price-warning" data-selector="price-warning">
                                        {{ iconset.iconPriceWarning() }}
                                        <span>{{ theme.settings.user_price_warning }}</span>
                                    </a>
                                </div>
                            {% endif %}
                            {% if theme.settings.display_social_share_button %}
                                <div class="product-social">
                                    <a href="javascript:void(0);" class="openbox product-social-icon" data-target="product-social-content">
                                        {{ iconset.iconShare() }}
                                        <span>{{ theme.settings.user_share }}</span>
                                    </a>
                                    <div class="product-social-content openbox-content">
                                        <div>
                                            <div>
                                                <a href="javascript:void(0);" class="product-social-facebook" data-selector="share-link" data-type="facebook">
                                                    {{ iconset.iconProductFacebook() }}
                                                </a>
                                            </div>
                                            <div>
                                                <a href="javascript:void(0);" class="product-social-twitter" data-selector="share-link" data-type="twitter">
                                                    {{ iconset.iconProductTwitter() }}
                                                </a>
                                            </div>
                                            <div>
                                                <a href="javascript:void(0);" class="product-social-pinterest" data-selector="share-link" data-type="pinterest">
                                                    {{ iconset.iconProductPinterest() }}
                                                </a>
                                            </div>
                                            <div>
                                                <a href="javascript:void(0);" class="product-social-whatsapp" data-selector="share-link" data-type="whatsapp">
                                                    {{ iconset.iconProductWhatsapp() }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                            {% if theme.settings.display_compare_button %}
                                <div class="product-compare">
                                    <a href="javascript:void(0);" class="{{ isComparedProduct(product.id) ? ' active' : '' }}" data-selector="compare-check" data-product-id="{{ product.id }}">
                                        {{ iconset.iconCompare() }}
                                        <span>{{ getLang("_Compare_") }}</span>
                                    </a>
                                </div>
                            {% endif %}
                            {% if theme.settings.display_comment_buttons %}
                                <div>
                                    <a href="javascript:void(0);" class="add-comment" data-selector="add-comment">
                                        {{ iconset.iconComment() }}
                                        <span>{{ theme.settings.user_add_comment }}</span>
                                    </a>
                                </div>
                            {% endif %}
                            {% if theme.settings.display_recommend_buttons %}
                                <div>
                                    <a href="javascript:void(0);" class="recommend-product" data-selector="recommend-product">
                                        {{ iconset.iconRecommend() }}
                                        <span>{{ theme.settings.user_recommend_product }}</span>
                                    </a>
                                </div>
                            {% endif %}                                                        
                        </div>
                    {% endif %}
				</div>
			</div>
		</div>
	</div>
	<div class="product-area-bottom">
        {% include 'html/snippets/product/tab.twig' %}
		{% include 'html/snippets/product/promotion.twig' %}
		{% if similar_product_showcase_items | length > 0 %}
			<div class="default-products similar-products">
                {% if theme.settings.similar_products_title %}
                    <div class="products-header">
                        <h2 class="section-title">{{ theme.settings.similar_products_title }}</h2>
                    </div>
                {% endif %}
				<div class="products-content row">
					{% for item in similar_product_showcase_items %}
						<div class="col-auto">
							{% include 'html/snippets/showcase-item.twig' %}
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}
		{% if offered_product_showcase_items | length > 0 %}
			<div class="default-products offered-products">
                {% if theme.settings.offered_products_title %}
                    <div class="products-header">
                        <h2 class="section-title">{{ theme.settings.offered_products_title }}</h2>
                    </div>
                {% endif %}
				<div class="products-content row">
					{% for item in offered_product_showcase_items %}
						<div class="col-auto">
							{% include 'html/snippets/showcase-item.twig' %}
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}
		{% if combine_product_showcase_items | length > 0 %}
			<div class="default-products combined-products">
                {% if theme.settings.combine_products_title %}
                    <div class="products-header">
                        <h2 class="section-title">{{ theme.settings.combine_products_title }}</h2>
                    </div>
                {% endif %}
				<div class="products-content row">
					{% set showcase = {'type':'CombineProducts'} %}
					{% for item in combine_product_showcase_items %}
						<div class="col-auto">
							{% include 'html/snippets/showcase-item.twig' %}
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}
		{% if product.tags | length > 0 %}
			<div class="product-tags">
				<div class="product-tags-title">{{ getLang("_LabelFilter_") }} :</div>
				<div class="product-tags-content">
					{% for tag in product.tags %}
						<a href="{{ tag.url }}" title="{{ tag.name }}" target="_blank">{{ tag.name }}</a>
					{% endfor %}
				</div>
			</div>
		{% endif %}
	</div>
	{% if theme.settings.use_rich_snippets %}
		{% include 'html/snippets/product/rich-snippet.twig' %}
	{% endif %}
	{% include 'html/snippets/product/tracking.twig' %}
	{% include 'html/snippets/product/form/add-comment.twig' %}
	{% include 'html/snippets/product/form/send-recommend.twig' %}
    {% include 'html/snippets/product/form/add-question.twig' %}
</div>
{% endblock %}